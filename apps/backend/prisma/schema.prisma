// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE TENANT & AUTH MODELS
// ============================================

model Company {
  id                String      @id @default(cuid())
  name              String
  email             String      @unique
  phone             String?
  address           String?
  city              String?
  state             String?
  postalCode        String?
  country           String?
  logo              String?
  website           String?
  industry          String?
  size              String?     // small, medium, large
  subscriptionPlan  String      @default("free") // free, pro, enterprise
  subscriptionUntil DateTime?
  isActive          Boolean     @default(true)
  deletedAt         DateTime?

  // Relations
  users             User[]
  departments       Department[]
  employees         Employee[]
  customers         Customer[]
  suppliers         Supplier[]
  categories        Category[]
  products          Product[]
  inventoryTransactions InventoryTransaction[]
  purchaseOrders    PurchaseOrder[]
  salesOrders       SalesOrder[]
  invoices          Invoice[]
  payments          Payment[]
  attendance        Attendance[]
  leaves            Leave[]
  payrolls          Payroll[]
  journalEntries    JournalEntry[]
  auditLogs         AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([subscriptionPlan])
}

model Role {
  id          String      @id @default(cuid())
  name        String      // super_admin, company_admin, employee
  description String?
  isSystem    Boolean     @default(false)

  permissions Permission[]
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  // e.g., "users:create", "inventory:read"
  description String?

  roles Role[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  firstName     String
  lastName      String
  password      String  // hashed
  phone         String?
  isEmailVerified Boolean @default(false)
  emailVerifyToken String?
  emailVerifyTokenExpires DateTime?
  isActive      Boolean @default(true)
  lastLogin     DateTime?
  deletedAt     DateTime?

  // Tenant & Auth
  companyId     String
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleId        String
  role          Role    @relation(fields: [roleId], references: [id])

  // Relations
  employee      Employee?
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([roleId])
  @@index([isActive])
}

// ============================================
// ORGANIZATIONAL MODELS
// ============================================

model Department {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String
  description String?
  deletedAt DateTime?

  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
}

model Employee {
  id              String  @id @default(cuid())
  companyId       String
  company         Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId      String  // Human-readable ID
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  designation     String
  salary          Float?
  joiningDate     DateTime
  status          String  @default("active") // active, inactive, on_leave
  deletedAt       DateTime?

  attendance      Attendance[]
  leaves          Leave[]
  payrolls        Payroll[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, employeeId])
  @@index([companyId])
  @@index([departmentId])
}

// ============================================
// CUSTOMER & SUPPLIER MODELS
// ============================================

model Customer {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String?
  address     String?
  city        String?
  state       String?
  postalCode  String?
  country     String?
  gstNumber   String?
  status      String  @default("active")
  deletedAt   DateTime?

  salesOrders SalesOrder[]
  invoices    Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Supplier {
  id            String  @id @default(cuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  gstNumber     String?
  status        String  @default("active")
  deletedAt     DateTime?

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// ============================================
// INVENTORY MODELS
// ============================================

model Category {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String
  description String?
  deletedAt DateTime?

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
}

model Product {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sku         String
  name        String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  brand       String?
  unit        String  // pcs, kg, ltr, etc
  costPrice   Float
  sellingPrice Float
  quantity    Int     @default(0)
  reorderLevel Int    @default(10)
  barcode     String?
  status      String  @default("active")
  deletedAt   DateTime?

  inventoryTransactions InventoryTransaction[]
  purchaseItems         PurchaseItem[]
  salesItems            SalesItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([categoryId])
}

model InventoryTransaction {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  type        String  // in, out, adjustment
  quantity    Int
  notes       String?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([productId])
  @@index([type])
}

// ============================================
// PURCHASE MODELS
// ============================================

model PurchaseOrder {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  poNumber    String
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  status      String  @default("draft") // draft, pending, approved, received, cancelled
  poDate      DateTime
  dueDate     DateTime?
  totalAmount Float   @default(0)
  notes       String?
  deletedAt   DateTime?

  items       PurchaseItem[]
  payments    Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, poNumber])
  @@index([companyId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseItem {
  id          String  @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  receivedQty Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poId])
  @@index([productId])
}

// ============================================
// SALES MODELS
// ============================================

model SalesOrder {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  soNumber    String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  status      String  @default("draft") // draft, pending, approved, shipped, delivered, cancelled
  soDate      DateTime
  dueDate     DateTime?
  totalAmount Float   @default(0)
  notes       String?
  deletedAt   DateTime?

  items       SalesItem[]
  invoices    Invoice[]
  payments    Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, soNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
}

model SalesItem {
  id          String  @id @default(cuid())
  soId        String
  so          SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  shippedQty  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([soId])
  @@index([productId])
}

// ============================================
// BILLING & PAYMENT MODELS
// ============================================

model Invoice {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceNumber String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  soId        String?
  so          SalesOrder? @relation(fields: [soId], references: [id])
  invoiceDate DateTime
  dueDate     DateTime
  totalAmount Float
  paidAmount  Float   @default(0)
  status      String  @default("draft") // draft, issued, paid, overdue, cancelled
  notes       String?
  deletedAt   DateTime?

  payments    Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
}

model Payment {
  id            String  @id @default(cuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  poId          String?
  po            PurchaseOrder? @relation(fields: [poId], references: [id])
  soId          String?
  so            SalesOrder? @relation(fields: [soId], references: [id])
  invoiceId     String?
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])
  amount        Float
  paymentDate   DateTime
  paymentMethod String  // cash, check, bank_transfer, credit_card
  referenceNo   String?
  status        String  @default("pending") // pending, completed, cancelled
  notes         String?
  deletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([poId])
  @@index([soId])
  @@index([invoiceId])
}

// ============================================
// HR MODELS
// ============================================

model Attendance {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      String  // present, absent, leave
  notes       String?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, employeeId, date])
  @@index([companyId])
  @@index([employeeId])
}

model Leave {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String  // sick, casual, unpaid, maternity
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      String  @default("pending") // pending, approved, rejected, cancelled
  reason      String?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
}

model Payroll {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month       DateTime
  baseSalary  Float
  bonuses     Float   @default(0)
  deductions  Float   @default(0)
  taxes       Float   @default(0)
  netSalary   Float
  status      String  @default("draft") // draft, approved, paid, cancelled
  notes       String?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, employeeId, month])
  @@index([companyId])
  @@index([employeeId])
}

// ============================================
// ACCOUNTING MODELS
// ============================================

model JournalEntry {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entryDate   DateTime
  description String
  reference   String?
  totalDebit  Float
  totalCredit Float
  status      String  @default("draft") // draft, posted, reversed
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

// ============================================
// AUDIT & LOGGING
// ============================================

model AuditLog {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String  // create, update, delete, login, logout
  entity      String  // e.g., User, Invoice, PurchaseOrder
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  deletedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([action])
  @@index([entity])
}
